APP_NAME="Akaunting MCP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://accounting-mcp.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# This app does not use a database — set everything to file-based
DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=log

# Akaunting instance URL (no trailing slash)
# Example: https://accounting.yourdomain.com
AKAUNTING_BASE_URL=

# Default company to operate on. Akaunting requires a company_id on every
# request. MCP clients can override this per connection with an X-Company-ID
# header; otherwise this default is used.
AKAUNTING_COMPANY_ID=1

# Troubleshooting: when true, every Akaunting API request and response is logged
# to storage/logs/laravel.log. Failed requests (e.g. 422 validation errors) are
# always logged with their full response body. To see the verbose request/response
# lines as well, also set LOG_LEVEL=debug above. Leave off in normal production.
AKAUNTING_DEBUG=false
